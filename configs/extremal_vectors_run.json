{
  "repo_path": "/home/leanagent/math/extremal_vectors_tablets",
  "state_dir": ".agent-supervisor",
  "max_cycles": 100,
  "sleep_seconds": 2.0,
  "startup_timeout_seconds": 120.0,
  "burst_timeout_seconds": 7200,

  "worker": {
    "provider": "codex",
    "model": "gpt-5.4",
    "effort": "xhigh"
  },
  "easy_worker": {
