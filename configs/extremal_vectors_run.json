    "model": "auto",
    "fallback_models": ["gemini-3.1-pro-preview", "gemini-2.5-pro", "gemini-2.5-flash"]
  },
  "hard_worker": {
    "provider": "codex",
    "model": "gpt-5.4",
    "effort": "xhigh"
  },
  "reviewer": {
    "provider": "codex",
    "model": "gpt-5.4",
    "effort": "xhigh"
  },
  "verification": {
    "provider": "codex",
    "model": "gpt-5.4",
    "extra_args": [],
    "correspondence_agents": [
      {
        "provider": "claude",
        "model": "claude-opus-4-6",
        "effort": "max",
        "label": "Claude Opus max"
      },
      {
        "provider": "gemini",
        "model": "gemini-3.1-pro-preview",
        "fallback_models": ["gemini-2.5-pro", "gemini-2.5-flash"],
        "label": "Gemini 3.1 Pro"
      },
      {
        "provider": "codex",
        "model": "gpt-5.4",
        "effort": "xhigh",
        "label": "Codex 5.4 xhigh"
      }
    ],
    "soundness_agents": [
      {
        "provider": "claude",
        "model": "claude-opus-4-6",
        "effort": "max",
        "label": "Claude Opus max"
      },
      {
        "provider": "gemini",
        "model": "gemini-3.1-pro-preview",
        "fallback_models": ["gemini-2.5-pro", "gemini-2.5-flash"],
        "label": "Gemini 3.1 Pro"
      },
      {
        "provider": "codex",
        "model": "gpt-5.4",
        "effort": "xhigh",
        "label": "Codex 5.4 xhigh"
      }
    ]
  },

  "tmux": {
    "session_name": "extremal_vectors",
    "dashboard_window_name": "dashboard",
    "kill_windows_after_capture": false,
    "burst_user": "lagentworker",
    "burst_group": "leanagent"
  },

  "workflow": {
    "start_phase": "theorem_stating",
    "paper_tex_path": "paper/Extremal_Vectors.tex",
    "approved_axioms_path": "APPROVED_AXIOMS.json",
    "allowed_import_prefixes": ["Mathlib"],
    "forbidden_keyword_allowlist": [],
    "human_input_path": "HUMAN_INPUT.md",
    "input_request_path": "INPUT_REQUEST.md"
  },

  "chat": {
    "root_dir": ".agent-supervisor/chats",
    "repo_name": "extremal-vectors",
    "project_name": "Extremal Vectors Formalization"
  },

  "git": {
    "remote_url": null,
    "remote_name": "origin",
    "branch": "master",
    "author_name": "lagent-supervisor",
    "author_email": "lagent@localhost"
  },

  "branching": {
    "max_current_branches": 1
  }
}
